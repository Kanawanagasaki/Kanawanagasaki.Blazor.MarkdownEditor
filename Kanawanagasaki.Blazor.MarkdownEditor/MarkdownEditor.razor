@inherits MarkdownEditorBase
@namespace Kanawanagasaki.Blazor.MarkdownEditor

<div class="md-editor" @attributes="AdditionalAttributes">
    @if (ShowToolbar)
    {
        <div class="md-toolbar">
            <div class="md-toolbar-row">
                @* ── undo / redo ── *@
                <button type="button" class="md-btn" title="Undo (Ctrl+Z)"
                        disabled="@Disabled"
                        @onclick="NativeUndo">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10h13a4 4 0 0 1 0 8H9"/><polyline points="7 14 3 10 7 6"/></svg>
                </button>
                <button type="button" class="md-btn" title="Redo (Ctrl+Y)"
                        disabled="@Disabled"
                        @onclick="NativeRedo">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10H8a4 4 0 0 0 0 8h7"/><polyline points="17 14 21 10 17 6"/></svg>
                </button>

                <span class="md-sep"></span>

                @* ── headings ── *@
                <button type="button" class="md-btn md-btn-text" title="Heading 1"
                        disabled="@Disabled"
                        @onclick="() => ApplyHeading(1)">H1</button>
                <button type="button" class="md-btn md-btn-text" title="Heading 2"
                        disabled="@Disabled"
                        @onclick="() => ApplyHeading(2)">H2</button>
                <button type="button" class="md-btn md-btn-text" title="Heading 3"
                        disabled="@Disabled"
                        @onclick="() => ApplyHeading(3)">H3</button>

                <span class="md-sep"></span>

                @* ── inline formatting ── *@
                <button type="button" class="md-btn md-btn-bold" title="Bold (Ctrl+B)"
                        disabled="@Disabled"
                        @onclick="ApplyBold">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/><path d="M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/></svg>
                </button>
                <button type="button" class="md-btn md-btn-italic" title="Italic (Ctrl+I)"
                        disabled="@Disabled"
                        @onclick="ApplyItalic">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/><line x1="15" y1="4" x2="9" y2="20"/></svg>
                </button>
                <button type="button" class="md-btn" title="Strikethrough"
                        disabled="@Disabled"
                        @onclick="ApplyStrikethrough">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4H9a3 3 0 0 0-3 3v0a3 3 0 0 0 3 3h6a3 3 0 0 1 0 6H8"/><line x1="4" y1="12" x2="20" y2="12"/></svg>
                </button>

                <span class="md-sep"></span>

                @* ── code ── *@
                <button type="button" class="md-btn" title="Inline Code"
                        disabled="@Disabled"
                        @onclick="ApplyInlineCode">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                </button>
                <button type="button" class="md-btn" title="Code Block"
                        disabled="@Disabled"
                        @onclick="InsertCodeBlock">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><polyline points="9 8 5 12 9 16"/><polyline points="15 8 19 12 15 16"/></svg>
                </button>

                <span class="md-sep"></span>

                @* ── lists ── *@
                <button type="button" class="md-btn" title="Unordered List"
                        disabled="@Disabled"
                        @onclick="ApplyUnorderedList">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><circle cx="3.5" cy="6" r="1.5" fill="currentColor"/><circle cx="3.5" cy="12" r="1.5" fill="currentColor"/><circle cx="3.5" cy="18" r="1.5" fill="currentColor"/></svg>
                </button>
                <button type="button" class="md-btn" title="Ordered List"
                        disabled="@Disabled"
                        @onclick="ApplyOrderedList">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="10" y1="6" x2="21" y2="6"/><line x1="10" y1="12" x2="21" y2="12"/><line x1="10" y1="18" x2="21" y2="18"/><text x="2" y="8" font-size="9" fill="currentColor" stroke="none" font-family="sans-serif">1</text><text x="2" y="14" font-size="9" fill="currentColor" stroke="none" font-family="sans-serif">2</text><text x="2" y="20" font-size="9" fill="currentColor" stroke="none" font-family="sans-serif">3</text></svg>
                </button>

                <span class="md-sep"></span>

                @* ── blockquote ── *@
                <button type="button" class="md-btn" title="Blockquote"
                        disabled="@Disabled"
                        @onclick="ApplyBlockquote">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.76-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.76-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21z"/></svg>
                </button>

                <span class="md-sep"></span>

                @* ── link / image ── *@
                <button type="button" class="md-btn" title="Insert Link"
                        disabled="@Disabled"
                        @onclick="InsertLink">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                </button>
                <button type="button" class="md-btn" title="Insert Image"
                        disabled="@Disabled"
                        @onclick="InsertImage">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                </button>

                @* ── horizontal rule ── *@
                <button type="button" class="md-btn" title="Horizontal Rule"
                        disabled="@Disabled"
                        @onclick="InsertHorizontalRule">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="2" y1="12" x2="22" y2="12"/></svg>
                </button>
            </div>
        </div>
    }

    <div class="md-editor-body" @ref="_editorBody">
        @* Textarea: transparent input layer, scroll model, no pointer events.
           Input/key events are handled in JS (not Blazor @oninput/@onkeydown)
           because pointer-events:none prevents Blazor's event binding from firing. *@
        <textarea class="md-textarea"
                  @ref="_textarea"
                  disabled="@Disabled"
                  placeholder="@Placeholder"
                  spellcheck="false"
                  autocomplete="off"
                  autocorrect="off"
                  autocapitalize="off">
        </textarea>

        @* Overlay: visual layer, captures clicks and wheel events *@
        <div class="md-overlay" @ref="_overlay">
            @((MarkupString)_renderedHtml)
        </div>

        @* Simulated cursor: positioned by JS on top of everything *@
        <div class="md-cursor" @ref="_cursor"></div>
    </div>
</div>
